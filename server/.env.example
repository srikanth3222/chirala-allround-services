# ─── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/service-marketplace?retryWrites=true&w=majority

# ─── Auth ──────────────────────────────────────────────────────────────────────
# IMPORTANT: Use a long random string (min 32 chars) in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_KEY

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=production

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CLIENT_URL=https://yourproductiondomain.com

# ─── SMS (OTP) ─────────────────────────────────────────────────────────────────
# Integrate Twilio or MSG91 before going live
# TWILIO_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE=
